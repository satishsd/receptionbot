# Server
PORT=3000
NODE_ENV=production

# Database
# CloudPanel PostgreSQL connection string.
# Find your credentials in CloudPanel -> Databases -> your database -> Show Credentials.
# Full format: ******127.0.0.1:5432/DB_NAME?schema=public
DATABASE_URL="******127.0.0.1:5432/receptionbot?schema=public"

# App
APP_NAME="ReceptionBot"
APP_VERSION="1.0.0"

# Admin Panel
# Username and password for the /admin dashboard login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
# Secret used to sign admin session tokens - change this to a long random string
ADMIN_SECRET=replace-with-a-long-random-secret

# WhatsApp Cloud API (Meta)
# The verify token you set when registering the webhook in Meta's App Dashboard
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
# Your permanent access token (from Meta Developer Console -> WhatsApp -> API Setup)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
# The Phone Number ID shown in Meta App Dashboard -> WhatsApp -> API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Cron job retention settings (optional, defaults shown)
# How many days to keep stale web sessions before cleanup
SESSION_RETENTION_DAYS=30
# How many days to keep processed webhook events before cleanup
WEBHOOK_RETENTION_DAYS=7
